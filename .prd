      "converse-view"
    ],
    "blockedBy": [],
    "effort": "medium",
    "category": "feature",
    "acceptance": [
      "POST /api/converse/start returns {id, message, topicsSummary} where message is the AI's opening statement about today's material",
      "POST /api/converse/turn with {message} returns {reply} from AI with conversation context",
      "GET /api/converse returns {history, topics} for current day",
      "Conversation is syllabus-agnostic: uses manifest.promptTemplates.sessionCoach as system prompt",
      "History persists across requests within same day"
    ],
    "edge_cases": [
      "No due cards today — AI discusses general weak areas from stats instead",
      "AI CLI not available — return error JSON not crash",
      "Conversation JSON corrupt — reinitialize cleanly"
    ]
  },
